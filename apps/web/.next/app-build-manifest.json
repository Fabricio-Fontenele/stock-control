      "static/chunks/app/(protected)/produtos/page.js"
    ],
    "/(protected)/categorias/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(protected)/categorias/page.js"
    ],
    "/(protected)/produtos/[productId]/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(protected)/produtos/[productId]/page.js"
    ]
