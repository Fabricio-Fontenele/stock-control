{
  "name": "stoque-controll-convenience",
  "version": "0.1.0",
  "private": true,
  "description": "API de controle de estoque para conveniencia de posto",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:contract": "vitest run tests/contract",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:migrate": "tsx src/infrastructure/persistence/postgres/migrate.ts",
    "db:seed:admin": "tsx src/infrastructure/persistence/postgres/seed-admin.ts",
    "db:seed:catalog": "tsx src/infrastructure/persistence/postgres/seed-catalog.ts"
  },
  "dependencies": {
    "@fastify/jwt": "^9.1.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.1",
    "pg": "^8.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
